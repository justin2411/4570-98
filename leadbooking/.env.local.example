# ================================================
# LEADBOOKING – Umgebungsvariablen
# Kopieren nach: .env.local
# ================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein_anon_key
SUPABASE_SERVICE_ROLE_KEY=dein_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Live)
PAYPAL_CLIENT_ID=dein_paypal_client_id
PAYPAL_CLIENT_SECRET=dein_paypal_client_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=dein_paypal_client_id

# VAPID Keys (Web Push)
# Generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=dein_vapid_public_key
VAPID_PRIVATE_KEY=dein_vapid_private_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=dein_vapid_public_key
VAPID_EMAIL=admin@leadbooking.de

# App URL
NEXT_PUBLIC_APP_URL=https://leadbooking.vercel.app
